@page
@model BeautyHealthStore.Pages.Admin.CreateModel

@{
    ViewData["Title"] = "Adaugă produs";
}

<h1>Adaugă produs nou</h1>

<form method="post">

    <div class="mb-3">
        <label class="form-label">Nume produs</label>
        <input asp-for="Product.Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Descriere</label>
        <textarea asp-for="Product.Description" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Preț</label>
        <input asp-for="Product.Price" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Stoc</label>
        <input asp-for="Product.Stock" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Imagine (URL)</label>
        <input asp-for="Product.ImageUrl" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Secțiune</label>
        <select asp-for="Product.Section" class="form-select">
            <option value="Infrumusetare">Înfrumusețare</option>
            <option value="Sanatate">Sănătate</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Categorie</label>
        <select asp-for="Product.CategoryId"
                asp-items="Model.Categories"
                class="form-select">
        </select>
    </div>

    <div class="form-check">
        <input asp-for="Product.IsNew" class="form-check-input" />
        <label class="form-check-label">Produs nou</label>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Product.IsBestSeller" class="form-check-input" />
        <label class="form-check-label">Cel mai cumpărat</label>
    </div>

    <button type="submit" class="btn btn-success">
        Salvează produsul
    </button>

    <a asp-page="./Index" class="btn btn-secondary">
        Înapoi
    </a>

</form>