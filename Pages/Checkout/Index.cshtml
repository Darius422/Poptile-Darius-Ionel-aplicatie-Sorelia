@page
@model BeautyHealthStore.Pages.Checkout.IndexModel
@{
    ViewData["Title"] = "Finalizare comandă";
}
<h1>Finalizare comandă</h1>
@if (!Model.CartItems.Any())
{
    <div class="alert alert-info">
        Coșul este gol. Nu poți plasa o comandă.
    </div>
}
else
{
    <div class="row">
        <div class="col-md-7">
            <h4>Date client</h4>
            <form method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label class="form-label">Nume complet</label>
                    <input asp-for="Order.CustomerName" class="form-control" />
                    <span asp-validation-for="Order.CustomerName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Order.CustomerEmail" class="form-control" />
                    <span asp-validation-for="Order.CustomerEmail" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Adresă livrare</label>
                    <textarea asp-for="Order.Address" class="form-control"></textarea>
                    <span asp-validation-for="Order.Address" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-success">
                    Plasează comanda
                </button>
                <a asp-page="/Cart/Index" class="btn btn-secondary">
                    Înapoi la coș
                </a>
            </form>
        </div>
        <div class="col-md-5">
            <h4>Rezumat comandă</h4>
            <ul class="list-group mb-3">
                @foreach (var item in Model.CartItems)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        <span>@item.Product?.Name x @item.Quantity</span>
                        <strong>@((item.Product?.Price ?? 0) * item.Quantity) lei</strong>
                    </li>
                }
            </ul>
            <h4>Total: @Model.Total lei</h4>
        </div>
    </div>
}