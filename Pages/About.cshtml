@page
@model BeautyHealthStore.Pages.AboutModel

@{
    ViewData["Title"] = "Despre noi";
}

<div class="container">

    <div class="p-5 mb-5 rounded-4 shadow-sm"
         style="background: linear-gradient(135deg,#fde8ee,#fff7f9);">

        <h1 class="display-5 fw-bold">Despre Sorelia</h1>

        <p class="lead mt-3">
            Frumusețe și sănătate într-un singur loc.
        </p>

        <p>
            Sorelia este un magazin online dedicat persoanelor care își doresc
            produse de îngrijire și sănătate atent selectate.
        </p>

        <p>
            Ne propunem să oferim o experiență simplă și plăcută de cumpărare,
            punând la dispoziția clienților produse pentru îngrijirea feței,
            corpului, părului și produse naturiste pentru starea de bine.
        </p>

        <p>
            Prin Sorelia, dorim să promovăm un stil de viață echilibrat,
            bazat pe grijă față de sănătate și frumusețe.
        </p>
    </div>

    <div class="row">

        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <h3>🌸</h3>
                    <h5>Misiunea noastră</h5>
                    <p>
                        Oferirea unor produse de calitate pentru îngrijire și sănătate.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <h3>🌿</h3>
                    <h5>Calitate</h5>
                    <p>
                        Selectăm produse care răspund nevoilor clienților noștri.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <h3>💎</h3>
                    <h5>Încredere</h5>
                    <p>
                        Construim o relație bazată pe transparență și profesionalism.
                    </p>
                </div>
            </div>
        </div>

    </div>
</div>
