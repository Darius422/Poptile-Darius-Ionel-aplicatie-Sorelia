@page
@model BeautyHealthStore.Pages.ContactModel

@{
    ViewData["Title"] = "Contact";
}

<div class="container">

    <div class="p-5 mb-5 rounded-4 shadow-sm"
         style="background: linear-gradient(135deg,#fde8ee,#fff7f9);">

        <h1 class="display-5 fw-bold">Contact</h1>

        <p class="lead mt-3">
            Suntem aici pentru a răspunde întrebărilor tale.
        </p>

        <p>
            Dacă ai nevoie de informații despre produse, comenzi sau livrare,
            ne poți contacta folosind datele de mai jos.
        </p>
    </div>

    <div class="row">

        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm h-100 text-center">
                <div class="card-body">
                    <h2>📧</h2>
                    <h5>Email</h5>
                    <p>contact@sorelia.ro</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm h-100 text-center">
                <div class="card-body">
                    <h2>📞</h2>
                    <h5>Telefon</h5>
                    <p>0740 123 456</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm h-100 text-center">
                <div class="card-body">
                    <h2>📍</h2>
                    <h5>Adresă</h5>
                    <p>Negrești-Oaș, România</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm h-100 text-center">
                <div class="card-body">
                    <h2>🕒</h2>
                    <h5>Program</h5>
                    <p>Luni - Vineri<br />09:00 - 18:00</p>
                </div>
            </div>
        </div>

    </div>
</div>